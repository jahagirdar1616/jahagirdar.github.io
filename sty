body {
    font-family: Arial, sans-serif;
    margin: 0;
    background: #0f172a;
    color: white;
    text-align: center;
}

header {
    background: #1e293b;
    padding: 20px;
}

section {
    margin: 20px;
    padding: 20px;
    background: #1e293b;
    border-radius: 10px;
}

input {
    padding: 10px;
    width: 60%;
}

button {
    padding: 10px 15px;
    background: #22c55e;
    border: none;
    color: white;
    cursor: pointer;
}
